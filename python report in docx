sub1 = Chapter(parent=main_ch, name="Sub Chapter 1")
sub2 = Chapter(parent=main_ch, name="Sub Chapter 2")
sub3 = Chapter(parent=main_ch, name="Sub Chapter 3")

# ---- Main Chapter Content ----
img_main = DocImage(parent=main_ch, name="Main Image", image=path1)
tbl_main = DocTable(parent=main_ch, name="Main Table", table=table1)

# ---- Sub Chapter 1 ----
img1 = DocImage(parent=sub1, name="Image 1", image=path2)
tbl1 = DocTable(parent=sub1, name="Table 1", table=table1)

# ---- Sub Chapter 2 ----
img2 = DocImage(parent=sub2, name="Image 2", image=path3)
tbl2 = DocTable(parent=sub2, name="Table 2", table=table1)

# ---- Sub Chapter 3 ----
img3 = DocImage(parent=sub3, name="Image 3", image=path4)
