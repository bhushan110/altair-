from report.hwxdocxtypes import *
import os

# Start Report Session
se = ReportSession()

# ---- Data Folder (your images, csv, template are here) ----
data_path = r"C:/Users/ajaguri/Downloads/buildtools/bvt/hwreport/core/data"

# ---- File Paths ----
path1 = os.path.join(data_path, "Iso View.png")
path2 = os.path.join(data_path, "top view.png")
path3 = os.path.join(data_path, "left side view.png")
path4 = os.path.join(data_path, "front view.png")
path5 = os.path.join(data_path, "unitsystem.csv")
