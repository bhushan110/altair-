def CreateAndFillTableData(tablename, parent, data):
    from hwutl import hwVariant
    table_data = hwreport.TableData(tablename, len(data), len(data[0]), parent.entity, parent.mdimodel.name)
    for i, row in enumerate(data):
        for j, value in enumerate(row):
            table_data.SetValue(i, j, hwVariant(value))
           
    table_entity = hwdescriptor.Entity()
    table_data.GetTable(table_entity)
   
    table = MDIReportTable(parent.mdimodel, table_entity.uid.string)
    return table_data, table
