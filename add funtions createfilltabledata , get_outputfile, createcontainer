def get_output_type(output):
        library = None
        item = output
        while item:
            clsname = item.GetEntityFullType().GetTypeNamed().split('.')[-1]
            if clsname == "MDIReportPresentation":
                return "presentation"
            elif clsname == "MDIReportDocument":
                return "document"
            elif clsname == 'MDIReportPalette':
                library = item
                break
            item = item.owner
           
        if library:
            mdimodel = library.mdimodel
            sess = MDIReportSession(mdimodel, library.mdimodel.name)
            col = mdi.Collection(mdimodel, MDIReport)
            for item in col:
                reportitems = item.reportitems
                root = reportitems[0]
                if isinstance(root, MDIReportPresentation):
                    return "presentation"
                else:
                    return "document"
                break
               
        return None
 
