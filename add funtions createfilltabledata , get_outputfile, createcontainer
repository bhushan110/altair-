def createcontainer(output_type, parent, name=''):
    if output_type == "presentation":
        slide = MDIReportSlide(parent.mdimodel, str(uuid.uuid1()), owner=parent)
        slide.title = name
    else:
        slide = MDIReportChapter(parent.mdimodel, str(uuid.uuid1()), owner=parent)
    slide.name = name
 
    return slide
 
