    @staticmethod
    def model_statistics( context):
        from report.report_utils import initializeContext
        mdimodel,  mobj, entity_type = initializeContext(context)
        
        if(mobj.IsValid):
            pg = MDIReportPlugin(mdimodel, str(uuid.uuid1()), owner=mobj)
