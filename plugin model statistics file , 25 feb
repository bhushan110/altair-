            self._executeHM()
        elif client == Platform.HV:
            self._executeHV()

    def _executeHM(self):
        # HM python api works only for active window.
        # If we need to capture statistics of different window, we need to make that window active.
        import hm.entities as ent
        active_page, active_window = getActivePageAndWindow()
        ext = self._getExtension()
        if ext.page != active_page or ext.window != active_window:
            makePageWindowActive(ext.page, ext.window)
            
        import hm
        model = hm.Model()
        
        nodes      = model.hm_count('nodes', 'all')
        elements   = model.hm_count('elements', 'all')
        components = model.hm_count('components', 'all')
        sets       = model.hm_count('sets', 'all')
        materials  = model.hm_count('materials', 'all')
        properties = model.hm_count('properties', 'all')
        systems    = model.hm_count('systems', 'all')
        loads      = model.hm_count('loads', 'all')
        
        nodes_count      = nodes[1].count if nodes[0].status == 0 else 0
        elements_count   = elements[1].count if elements[0].status == 0 else 0
        components_count = components[1].count if components[0].status == 0 else 0
        sets_count       = sets[1].count if sets[0].status == 0 else 0
        materials_count  = materials[1].count if materials[0].status == 0 else 0
        properties_count = properties[1].count if properties[0].status == 0 else 0
        systems_count    = systems[1].count if systems[0].status == 0 else 0
        loads_count      = loads[1].count if loads[0].status == 0 else 0
        
        table_data = []
        cell_no_data = str("")
        
        ext = self._getExtension()
        if ext.detailed_statistics:
            table_data.append(['Item', 'Type', 'Count'])
            table_data.append(['Nodes', cell_no_data, str(nodes_count)])
            table_data.append(['Elements', cell_no_data, str(elements_count)])
            
            element_details = {}
            zero_one_d_count = self._getElementCountBasedOnDimension(model, ModelStatistics.zero_d, element_details)
            zero_one_d_count += self._getElementCountBasedOnDimension(model, ModelStatistics.one_d, element_details)
            two_d_count = self._getElementCountBasedOnDimension(model, ModelStatistics.two_d, element_details)
            three_d_count = self._getElementCountBasedOnDimension(model, ModelStatistics.three_d, element_details)
            
            table_data.append([cell_no_data, 'Solid (3D)', str(three_d_count)])
            table_data.append([cell_no_data, 'Shell (2D)', str(two_d_count)])
            table_data.append([cell_no_data, 'Beam (1D)', str(zero_one_d_count)])
            
            elem_fulltype = ent.Element.fulltype
            for key, value in element_details.items():
                elemtype_lower = key.lower()
                status, res = model.hm_entityinfo_configtype(elem_fulltype, elemtype_lower)
                if status.status == 0 and 'currentConfigTypeName' in res.keys:
                    key = key + ' (' + res.currentConfigTypeName + ')'
                table_data.append([cell_no_data, key, str(value)])
                
            table_data.append(['Components', cell_no_data, str(components_count)])
            table_data.append(['Sets', cell_no_data, str(sets_count)])
            table_data.append(['Materials', cell_no_data, str(materials_count)])
            table_data.append(['Properties', cell_no_data, str(properties_count)])
            table_data.append(['Systems', cell_no_data, str(systems_count)])
            table_data.append(['Loads', cell_no_data, str(loads_count)])
            
            rows = len(table_data)
            columns = 3
        
        else:
            table_data.append(['Item', 'Count'])
            if nodes_count > 0:
                table_data.append(['Nodes', str(nodes_count)])
            if elements_count > 0:
                table_data.append(['Elements', str(elements_count)])
            if components_count > 0:
                table_data.append(['Components', str(components_count)])
            if sets_count > 0:
                table_data.append(['Sets', str(sets_count)])
            if materials_count > 0:
                table_data.append(['Materials', str(materials_count)])
            if properties_count > 0:
                table_data.append(['Properties', str(properties_count)])
            if systems_count > 0:
                table_data.append(['Systems', str(systems_count)])
                
            rows = len(table_data)
            columns = 2
            
        self._createTable(rows, columns, table_data)
        
        # Statistics captured for different window. Restore active window as before.
        if ext.page != active_page or ext.window != active_window:
            makePageWindowActive(active_page, active_window)
            
    def _executeHV(self):
        import hwi
        ext     = self._getExtension()
        session = hwi.getSessionHandle()
        project = session.getProjectHandle()
        page    = project.getPageHandle(ext.page)
        window  = page.getWindowHandle(ext.window)
        hv      = window.getClientHandle()
        model   = hv.getModelHandle(hv.activeModel)
        
        cell_no_data = str("")
        table_data = []
        table_data.append(['Entity Type', 'Pool/Config', 'Number of Entities'])
        
        pool_type_list = model.getPoolTypeList()
        for pool_type in pool_type_list:
            pool_type_count = model.getEntityCount(pool_type)
            display_name = None
            
            if pool_type == 'element':
                display_name = 'Elements'
                table_data.append([display_name, cell_no_data, str(pool_type_count)])
                
                config_list = model.getElementConfigList()
                for config in config_list:
                    config_count = model.getElementCount(config)
                    table_data.append([cell_no_data, config + ' (config)', str(config_count)])
            else:
                if 'node' in pool_type:
                    display_name = 'Nodes'
                elif 'part' in pool_type:
                    display_name = 'Components'
                elif 'system' in pool_type:
                    display_name = 'Systems'
                elif 'assembly' in pool_type:
                    display_name = 'Assemblies'
                elif 'set' in pool_type:
                    display_name = 'Sets'
                elif 'material' in pool_type:
                    display_name = 'Materials'
                elif 'property' in pool_type:
                    display_name = 'Properties'
                elif 'note' in pool_type:
                    display_name = 'Notes'
                table_data.append([display_name, cell_no_data, str(pool_type_count)])
                
            pool_list = model.getPoolList(pool_type)
            for pool in pool_list:
                pool_count = model.getEntityCount(pool_type, pool)
                pool_text = pool + ' (pool)' if pool_type == 'element' else pool
                table_data.append([cell_no_data, pool_text, str(pool_count)])
                
        rows = len(table_data)
        columns = 3
        self._createTable(rows, columns, table_data)
            
    def _setRowValue(self, table_if, row_index, values:list):
        for i, value in enumerate(values):
            table_if.SetValue(row_index, i, hwVariant(value))
            
    def _getElementCountBasedOnDimension(self, model, dimension, element_details):
        count = 0
        for key, value in dimension.items():
            elem = model.hm_count('elements', 'all', key)
            if elem[0].status == 0:
                count += elem[1].count
                
                if elem[1].count > 0:
                    element_details[value] = elem[1].count
        return count
        
    def showwidget(self, data):
        dlg = ModelStatisticsDialog(None, strategy=self.strategy, plugin=self.parent)
        dlg.show()
    
    def getwidgetclass(self):
        return "ModelStatisticsDialog"
    
        
    def _getExtension(self):
        plugin = self.parent
        for ext in plugin.extensions:
            if isinstance(ext, MDIModelStatisticsExt):
                return ext
        else:
            return None
        
    def _createTable(self, rows, cols, table_data):
        plugin = self.parent
        output_type = get_output_type(plugin)
        slide = createcontainer(output_type, plugin, 'Model Statistics')
        
        _, table = CreateAndFillTableData('Model Statistics', slide, table_data)
        table.caption = 'Model Statistics' if output_type == 'document' else ''
        table.stretch = False if output_type == 'document' else True    # Stretch made false for html. No effect on document.

        ext = self._getExtension()
        if ext is None:
            return
        table.splitAuto = ext.auto_split_table
        table.splitMaxRows = ext.maxrow
        table.splitMaxColumns = ext.maxcolumn

