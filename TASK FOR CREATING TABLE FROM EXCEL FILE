import uuid
import os
import mdi
from report.api import *
from report.hwxdocxtypes import *


def RunPlugin():

    s1 = ReportSession()
    model = mdi.Model(s1.name)
    doc = Document()
    print("Creating MDI Report Plugin for Excel Report")

    pg = MDIReportPlugin(model, str(uuid.uuid1()), owner=doc._metaobj)
    pg.name = "Excel Report"
    pg.cls = "ExcelReport"

    doc.update()

    outfile = os.path.join(os.path.expanduser("~"),"Documents","runplugin_docx.docx").replace("\\", "/")

    doc.saveDocx(outfile, open=True)
    print(f"Document saved to {outfile}")


if __name__ == "__main__":
    RunPlugin()


