class ExcelReport(ReportModule):

    def __init__(self):
        super().__init__()
        from report.api._private import PluginCategory, ReportEntityType

        self._plugin_category = PluginCategory.VALIDATE
        self._plugin_name = "ExcelReport"
        self._plugin_description = "Excel Report Plugin"
        self._plugin_version = "1.0.0"
        self._plugin_display_name = "Excel Report"
        self._supported_entity_types = [
            ReportEntityType.PRESENTATION,
            ReportEntityType.DOCUMENT
        ]

    @classmethod
    def displayname(cls):
        return "Excel Report"

    def execute(self, *args, **kwargs):

        print("Executing Excel Report Plugin report demo")
        file_path = "C:/Users/ajaguri/Documents/Book1.xlsx"

        wb = openpyxl.load_workbook(file_path)
        sheet = wb.active

        table_data = []

        for row in sheet.iter_rows(values_only=True):
            table_data.append([
                str(cell) if cell is not None else "" for cell in row
            ])

        rows = len(table_data)
        cols = len(table_data[0]) if rows > 0 else 0

        for r in table_data:
           for c in r:
              print(c, type(c))

        self._createTable(rows, cols, table_data)
        print("Excel Report Plugin execution completed")

    def CreateAndFillTableData(self,tablename, parent, data):
         print(f"Creating table data for table: {tablename} with {len(data)} rows and {len(data[0]) if len(data) > 0 else 0} columns")
         table_data = hwreport.TableData(tablename, len(data), len(data[0]), parent.entity, parent.mdimodel.name)
         for i, row in enumerate(data):
           for j, value in enumerate(row):
             table_data.SetValue(i, j, hwVariant(value))
             print(f"Set cell ({i}, {j}) to value: {value}")
         table_entity = hwdescriptor.Entity()
         table_data.GetTable(table_entity)
   
         table = MDIReportTable(parent.mdimodel, table_entity.uid.string)
         return table_data, table  
    
    def _createTable(self,rows, cols, table_data):

        rows = len(table_data)
        cols = len(table_data[0]) if rows > 0 else 0

        plugin = self.parent
        output_type = get_output_type(plugin)

        chapter = createcontainer(output_type, plugin, 'Excel Report')

        _,table = self.CreateAndFillTableData(
            'Excel Report',
            chapter,
            table_data
        )
        print(f"Created table with {rows} rows and {cols} columns")
        

